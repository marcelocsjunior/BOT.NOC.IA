# ==========================================
# ALTIS — .env.example
# baseline seguro para homologação / produção
# ==========================================

# --- identidade / build ---
BOT_VERSION=2026-03-16-dm-hybrid|build=2026-03-16_000000
BUILD_ID=2026-03-16_000000
TZ_LOCAL=America/Sao_Paulo

# --- telegram ---
TELEGRAM_BOT_TOKEN=000000000:REPLACE_ME
# alias compatível legado, se necessário
# BOT_TOKEN=000000000:REPLACE_ME

# --- unidade / paths ---
NOC_UNIT=UN1
NOC_DB_PATH=/var/lib/noc/noc.db
NOC_LOG_PATH=/var/log/mikrotik/un1.log
NOC_TAILER_STATE_PATH=/var/lib/noc/tailer.state.json

# --- freshness / timeline ---
NOC_DB_FRESHNESS_S=600
NOC_DB_EVENT_STALE_S=3600
NOC_TIMELINE_DEFAULT_N=30
NOC_MAX_TIMELINE_N=200
NOC_GROUP_MENTION_ONLY=true

# --- DM híbrida ---
DM_ASSISTANT_ENABLED=true
DM_ASSISTANT_SHADOW_MODE=false
DM_ASSISTANT_ALLOWED_CHAT_IDS=
DM_ASSISTANT_STYLE=light
DM_ASSISTANT_PROACTIVE=false
DM_ASSISTANT_MAX_REPLY_LINES=3
DM_ASSISTANT_MIN_CONFIDENCE=0.60

# acabamento factual por IA
DM_ASSISTANT_ENABLE_AI_FINISH=false

# classificador / roteador híbrido
DM_ASSISTANT_ENABLE_DM_ROUTER=true
DM_ASSISTANT_ENABLE_AI_CLASSIFIER=true
DM_ASSISTANT_CLASSIFIER_SHADOW_MODE=false
DM_ASSISTANT_ENABLE_CLARIFY=true
DM_ASSISTANT_ENABLE_SESSION_CONTEXT=true
DM_ASSISTANT_SESSION_TTL_S=600
DM_ASSISTANT_MAX_CLARIFY_TURNS=2
DM_ASSISTANT_ENABLE_SOCIAL=true
DM_ASSISTANT_ENABLE_GENERAL_HELP=true
DM_ASSISTANT_ENABLE_AI_GENERAL=true
DM_ASSISTANT_HUMOR_ENABLED=true

# --- IA Cloudflare Workers AI ---
AI_ENABLED=false
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AUTH_TOKEN=
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.1-8b-instruct
AI_TIMEOUT_S=12
AI_CACHE_TTL_S=300
AI_RL_PER_MIN=12

# --- ruído / filtros ---
NOC_NOISE_TOKENS=SELFTEST,PUSH-TEST,UN1 TEST,TEST
